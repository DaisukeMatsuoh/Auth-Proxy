# auth-proxy environment variables
# Copy this file to .env.auth-proxy and fill in the values.
#
# MODE: choose one or both of AUTH_PROXY_SERVE_PATH / AUTH_PROXY_UPSTREAM_APP_URL.
# At least one must be set — both unset causes a startup error.
#
# ── Static file mode (single binary, no Docker needed) ──────────────────────
# AUTH_PROXY_SERVE_PATH=/var/www/html
# AUTH_PROXY_LISTEN_ADDR=127.0.0.1:8080   # explicit 127.0.0.1 for non-container deploys
#
# ── Proxy mode (Docker Compose recommended) ──────────────────────────────────
# AUTH_PROXY_UPSTREAM_APP_URL=http://app:3000  # use Docker service name
# AUTH_PROXY_LISTEN_ADDR=0.0.0.0:8080     # 0.0.0.0 inside container; ports: controls exposure
#
# ── Combined mode (both static files and upstream proxy) ─────────────────────
# AUTH_PROXY_SERVE_PATH=/var/www/html
# AUTH_PROXY_UPSTREAM_APP_URL=http://app:3000
# ----------------------------------------------------------------------------

AUTH_PROXY_UPSTREAM_APP_URL=http://app:3000
# AUTH_PROXY_SERVE_PATH=/var/www/html

AUTH_PROXY_DB_PATH=/var/lib/auth-proxy/auth-proxy.db
AUTH_PROXY_LISTEN_ADDR=0.0.0.0:8080
AUTH_PROXY_SESSION_TTL_HOURS=8
AUTH_PROXY_ISSUER_NAME=my-service

# Generate each key with: openssl rand -hex 32
AUTH_PROXY_MFA_ENCRYPTION_KEY=
AUTH_PROXY_GUEST_TOKEN_SECRET=
AUTH_PROXY_GUEST_TOKEN_API_KEY=

RUST_LOG=info
